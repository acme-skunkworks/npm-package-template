# act reads .secrets by default for secret injection — ignore to prevent
# accidental commits if anyone later experiments with `act --secret-file`.
.secrets

.idea/
.vscode/
*.swp
*.swo

# preflight skill scratch output (written at the repo root on each run)
.preflight-summary.json

# Per-skill agent-skills config.json is generated by the initialise-skills skill,
# not committed (agent-skills v1.1.0 generated-config model, A-640). A tracked
# config.json would carry this repo's own values into every repo spawned from the
# template; the neutral config.example.json is the only config that ships. A
# generated repo runs the initialise-skills skill to materialise its own.
.claude/skills/*/config.json
.agents/skills/*/config.json
